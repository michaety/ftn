{
  "name": "ftn",
  "main": "./dist/index.js",
  "assets": {
    "directory": "./dist"
  },
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "vars": {
    "EXAMPLE_VALUE": "example_value"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ftn-db",
      "database_id": "b072df1a-a998-4789-a54c-4524b66f54e3"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "f71ca6a63dfe4fd39fb6eacaab42c39c",
      // For local development, create a preview namespace:
      // Run: npx wrangler kv:namespace create SESSION --preview
      "preview_id": "YOUR_KV_PREVIEW_ID_HERE"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "ftn-r2",
      "preview_bucket_name": "ftn-r2-preview"
    }
  ]
}
