---
import '@/styles/news.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Fishtank News</title>
</head>
<body>
  <header class="ftn-header">
    <div class="ftn-container">
      <div class="ftn-header-content" style="justify-content: center;">
        <div style="text-align: center; width: 100%;">
          <img src="/logo.webp" alt="logo" style="max-width: 200px; margin: 0 auto; display: block;">
        </div>
      </div>
    </div>
  </header>

  <main style="display: flex; justify-content: center; align-items: center; min-height: calc(100vh - 300px);">
    <form class="ftn-form" id="loginForm">
      <h2 class="ftn-form-title">Login</h2>
      
      <div class="ftn-form-group">
        <label for="email" class="ftn-label">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="ftn-input"
          required
        />
      </div>

      <div class="ftn-form-group">
        <label for="password" class="ftn-label">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="ftn-input"
          required
        />
      </div>

      <div id="error" class="ftn-error" style="display: none;"></div>

      <button type="submit" class="ftn-btn" style="width: 100%; margin-top: 20px;">
        Login
      </button>

      <p style="text-align: center; margin-top: 20px;">
        <a href="/forgot-password" style="color: var(--ink-black); text-decoration: underline;">Forgot Password?</a>
      </p>

      <p style="text-align: center; margin-top: 10px;">
        Don't have an account? <a href="/signup" style="color: var(--ink-black); font-weight: bold; text-decoration: underline;">Sign Up</a>
      </p>
    </form>
  </main>

  <footer class="ftn-footer">
    <div class="ftn-container">
      <div class="ftn-footer-content" style="justify-content: center; text-align: center;">
        <p>All trademarks, images and logos are the property of their respective owners. | <a href="https://fishtank.live" target="_blank" rel="noopener" style="text-decoration: underline;">fishtank.live</a></p>
      </div>
    </div>
  </footer>

  <script>
    const form = document.getElementById('loginForm');
    const errorDiv = document.getElementById('error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          // Redirect based on role
          if (data.user.role === 'admin') {
            window.location.href = '/news/admin';
          } else if (data.user.role === 'editor') {
            window.location.href = '/news/editor';
          } else {
            window.location.href = '/';
          }
        } else {
          errorDiv.textContent = data.error || 'Login failed';
          errorDiv.style.display = 'block';
        }
      } catch (error) {
        errorDiv.textContent = 'An error occurred. Please try again.';
        errorDiv.style.display = 'block';
      }
    });
  </script>
</body>
</html>
