---
import '@/styles/news.css';
---

<!DOCTYPE html>
<html lang="en" class="ftn-auth-page">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Fishtank News</title>
</head>
<body>
  <header class="ftn-header ftn-header-centered">
    <a href="/">
      <img src="/logo.webp" alt="Fishtank News logo" class="ftn-header-logo">
    </a>
  <header class="ftn-header">
    <div class="ftn-container">
      <div class="ftn-header-content">
        <img src="/logo.webp" alt="Fishtank News" class="ftn-auth-logo">
      </div>
    </div>
  </header>

  <main class="ftn-auth-main">
    <form class="ftn-auth-form" id="loginForm">
      <h2 class="ftn-form-title">Login</h2>
      
      <div class="ftn-form-group">
        <label for="email" class="ftn-label">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="ftn-input"
          required
        />
      </div>

      <div class="ftn-form-group">
        <label for="password" class="ftn-label">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="ftn-input"
          required
        />
      </div>

      <div id="error" class="ftn-error" style="display: none;"></div>

      <button type="submit" class="ftn-btn">
        Login
      </button>

      <p>
        <a href="/forgot-password">Forgot Password?</a>
      </p>

      <p>
        Don't have an account? <a href="/signup">Sign Up</a>
      </p>
    </form>
  </main>

  <footer class="ftn-footer">
    <div class="ftn-container">
      <div class="ftn-footer-content" style="justify-content: center; text-align: center;">
        <p>All trademarks, images and logos are the property of their respective owners. | <a href="https://fishtank.live" target="_blank" rel="noopener" style="text-decoration: underline;">fishtank.live</a></p>
      </div>
    </div>
  </footer>

  <script>
    const form = document.getElementById('loginForm');
    const errorDiv = document.getElementById('error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          // Redirect based on role
          if (data.user.role === 'admin') {
            window.location.href = '/news/admin';
          } else if (data.user.role === 'editor') {
            window.location.href = '/news/editor';
          } else {
            window.location.href = '/';
          }
        } else {
          errorDiv.textContent = data.error || 'Login failed';
          errorDiv.style.display = 'block';
        }
      } catch (error) {
        errorDiv.textContent = 'An error occurred. Please try again.';
        errorDiv.style.display = 'block';
      }
    });
  </script>
</body>
</html>
