---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getSession, getCookie, getArticlesByAuthor, getImageUrl } from '@/lib/db-utils';

// Check authentication
const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.SESSION;
const sessionId = getCookie(Astro.request, 'sessionId');
const session = await getSession(kv, sessionId);

if (!session || !['admin', 'editor'].includes(session.userRole)) {
  return Astro.redirect('/login');
}

// Fetch user's articles for initial load
const articles = await getArticlesByAuthor(db, session.userId);
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';
---

<NewsLayout title="Writer Dashboard" role="editor" userName={session.userName}>
  <style>
    /* 4-column grid layout for article tiles */
    .ftn-tile-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin: 20px 0;
    }
    
    @media (max-width: 1200px) {
      .ftn-tile-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    
    @media (max-width: 900px) {
      .ftn-tile-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 600px) {
      .ftn-tile-grid {
        grid-template-columns: 1fr;
      }
    }
    
    /* Compact tile card styles */
    .ftn-tile-card {
      background-color: var(--paper-white, #fdfaf5);
      border: 2px solid var(--ink-black, #1a1a1a);
      box-shadow: 3px 3px 0px rgba(0,0,0,0.1);
      overflow: hidden;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      display: flex;
      flex-direction: column;
    }
    
    .ftn-tile-card:hover {
      transform: translateY(-3px);
      box-shadow: 5px 5px 0px rgba(0,0,0,0.15);
    }
    
    .ftn-tile-image {
      width: 100%;
      height: 150px;
      overflow: hidden;
      background-color: var(--beige-bg, #f5f0e6);
    }
    
    .ftn-tile-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(100%) sepia(30%) contrast(1.1);
    }
    
    .ftn-tile-no-image {
      width: 100%;
      height: 150px;
      background-color: var(--beige-bg, #f5f0e6);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--aged-sepia, #8b7355);
      font-style: italic;
    }
    
    .ftn-tile-content {
      padding: 15px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    
    .ftn-tile-title {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      margin: 0 0 10px 0;
      line-height: 1.3;
      color: var(--ink-black, #1a1a1a);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    
    .ftn-tile-status {
      font-size: 0.75rem;
      font-weight: bold;
      text-transform: uppercase;
      padding: 3px 8px;
      display: inline-block;
      margin-bottom: 10px;
    }
    
    .ftn-tile-status.draft {
      background-color: #f0f0f0;
      color: #666;
    }
    
    .ftn-tile-status.published {
      background-color: #d4edda;
      color: #155724;
    }
    
    .ftn-tile-actions {
      margin-top: auto;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    
    .ftn-tile-btn {
      padding: 6px 12px;
      font-size: 0.75rem;
      border: 1px solid var(--ink-black, #1a1a1a);
      background-color: var(--ink-black, #1a1a1a);
      color: white;
      text-decoration: none;
      cursor: pointer;
      font-family: Georgia, serif;
      transition: all 0.2s ease;
    }
    
    .ftn-tile-btn:hover {
      background-color: var(--aged-sepia, #8b7355);
    }
    
    .ftn-tile-btn.delete {
      background-color: #dc3545;
      border-color: #dc3545;
    }
    
    .ftn-tile-btn.delete:hover {
      background-color: #c82333;
    }
    
    .ftn-tile-btn.view {
      background-color: #007bff;
      border-color: #007bff;
    }
    
    .ftn-tile-btn.view:hover {
      background-color: #0056b3;
    }
    
    /* Loading indicator for infinite scroll */
    .ftn-loading-indicator {
      grid-column: 1 / -1;
      text-align: center;
      padding: 30px;
      font-style: italic;
      color: var(--aged-sepia, #8b7355);
    }
  </style>

  <div class="ftn-container">
    <div class="ftn-dashboard">
      <div class="ftn-dashboard-header">
        <img src="/logo.webp" alt="Fishtank News" class="ftn-dashboard-logo" />
      </div>
      
      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">My Articles</h2>
        <div style="margin-bottom: 20px;">
          <a href="/writer/new" class="ftn-btn">Create New Article</a>
        </div>
        
        {articles.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">
            No articles yet. <a href="/writer/new" class="ftn-btn">Create your first article</a>
          </p>
        ) : (
          <div id="articles-grid" class="ftn-tile-grid">
            {articles.map((article: any) => {
              const statusClass = article.status === 'approved' ? 'published' : 'draft';
              const statusText = article.status === 'approved' ? 'Published' : 'Draft';
              const imageUrl = getImageUrl(article.featured_image, r2PublicUrl) || article.featured_image;
              
              return (
                <article class="ftn-tile-card" data-article-id={article.id}>
                  {article.featured_image ? (
                    <div class="ftn-tile-image">
                      <img src={imageUrl} alt={article.title} loading="lazy" />
                    </div>
                  ) : (
                    <div class="ftn-tile-no-image">No Image</div>
                  )}
                  
                  <div class="ftn-tile-content">
                    <h3 class="ftn-tile-title">{article.title}</h3>
                    <span class={`ftn-tile-status ${statusClass}`}>{statusText}</span>
                    
                    <div class="ftn-tile-actions">
                      <a href={`/writer/edit/${article.id}`} class="ftn-tile-btn">Edit</a>
                      {article.status === 'approved' && (
                        <a href={`/news/articles/${article.slug}`} target="_blank" class="ftn-tile-btn view">View</a>
                      )}
                      <button 
                        onclick={`deleteArticle(${article.id})`}
                        class="ftn-tile-btn delete"
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>

  <script>
    // Pagination state for infinite scroll
    let currentPage = 1;
    const pageSize = 20;
    let isLoading = false;
    let hasMoreArticles = true;
    
    // Get initial articles count from DOM
    const initialArticles = document.querySelectorAll('.ftn-tile-card');
    if (initialArticles.length < pageSize) {
      hasMoreArticles = false;
    }
    
    // Setup infinite scroll
    function setupInfiniteScroll() {
      window.addEventListener('scroll', async () => {
        if (isLoading || !hasMoreArticles) return;
        
        const scrollHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY;
        const clientHeight = window.innerHeight;
        
        // Load more when user is 200px from bottom
        if (scrollTop + clientHeight >= scrollHeight - 200) {
          await loadMoreArticles();
        }
      });
    }
    
    async function loadMoreArticles() {
      if (isLoading || !hasMoreArticles) return;
      isLoading = true;
      
      const container = document.getElementById('articles-grid');
      if (!container) return;
      
      // Add loading indicator
      const loadingEl = document.createElement('div');
      loadingEl.className = 'ftn-loading-indicator';
      loadingEl.id = 'scroll-loading';
      loadingEl.textContent = 'Loading more...';
      container.appendChild(loadingEl);
      
      try {
        // Fetch articles with pagination
        const response = await fetch(`/api/articles/my?page=${currentPage + 1}&limit=${pageSize}`);
        
        // Remove loading indicator
        const scrollLoading = document.getElementById('scroll-loading');
        if (scrollLoading) scrollLoading.remove();
        
        if (response.ok) {
          const data = await response.json();
          
          if (data.articles && data.articles.length > 0) {
            // Append new articles
            data.articles.forEach((article: any) => {
              const card = createArticleCard(article);
              container.insertAdjacentHTML('beforeend', card);
            });
            
            currentPage++;
            hasMoreArticles = data.articles.length === pageSize;
          } else {
            hasMoreArticles = false;
          }
        }
      } catch (error) {
        console.error('Error loading more articles:', error);
        const scrollLoading = document.getElementById('scroll-loading');
        if (scrollLoading) scrollLoading.remove();
      } finally {
        isLoading = false;
      }
    }
    
    function createArticleCard(article: any) {
      const statusClass = article.status === 'approved' ? 'published' : 'draft';
      const statusText = article.status === 'approved' ? 'Published' : 'Draft';
      
      return `
        <article class="ftn-tile-card" data-article-id="${article.id}">
          ${article.featured_image ? `
            <div class="ftn-tile-image">
              <img src="${article.featured_image}" alt="${article.title}" loading="lazy" />
            </div>
          ` : `
            <div class="ftn-tile-no-image">No Image</div>
          `}
          
          <div class="ftn-tile-content">
            <h3 class="ftn-tile-title">${article.title}</h3>
            <span class="ftn-tile-status ${statusClass}">${statusText}</span>
            
            <div class="ftn-tile-actions">
              <a href="/writer/edit/${article.id}" class="ftn-tile-btn">Edit</a>
              ${article.status === 'approved' ? `
                <a href="/news/articles/${article.slug}" target="_blank" class="ftn-tile-btn view">View</a>
              ` : ''}
              <button onclick="deleteArticle(${article.id})" class="ftn-tile-btn delete">Delete</button>
            </div>
          </div>
        </article>
      `;
    }
    
    (window as any).deleteArticle = async (id: number) => {
      if (!confirm('Are you sure you want to delete this article?')) return;
      
      try {
        const response = await fetch(`/api/articles/${id}`, { method: 'DELETE' });
        if (response.ok) {
          // Remove the card from DOM
          const card = document.querySelector(`[data-article-id="${id}"]`);
          if (card) {
            card.remove();
          }
          alert('Article deleted');
        } else {
          alert('Failed to delete article');
        }
      } catch (error) {
        alert('Error deleting article');
      }
    };
    
    // Initialize infinite scroll
    setupInfiniteScroll();
  </script>
</NewsLayout>
