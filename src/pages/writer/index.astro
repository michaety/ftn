---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getSession, getCookie, getArticlesByAuthor, getImageUrl } from '@/lib/db-utils';

// Check authentication
const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.SESSION;
const sessionId = getCookie(Astro.request, 'sessionId');
const session = await getSession(kv, sessionId);

if (!session || !['admin', 'editor'].includes(session.userRole)) {
  return Astro.redirect('/login');
}

// Fetch user's articles for initial load
const articles = await getArticlesByAuthor(db, session.userId);
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';
---

<NewsLayout title="Writer Dashboard" role="editor" userName={session.userName}>
  <div class="ftn-container">
    <div class="ftn-dashboard">
      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">My Articles</h2>
        <div style="margin-bottom: 20px;">
          <a href="/writer/new" class="ftn-btn">Create New Article</a>
        </div>
        
        {articles.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">
            No articles yet. <a href="/writer/new" class="ftn-btn">Create your first article</a>
          </p>
        ) : (
          <div id="articles-grid" class="ftn-tile-grid">
            {articles.map((article: any) => {
              const statusClass = article.status === 'approved' ? 'published' : 'draft';
              const statusText = article.status === 'approved' ? 'Published' : 'Draft';
              const imageUrl = getImageUrl(article.featured_image, r2PublicUrl) || article.featured_image;
              
              return (
                <article class="ftn-tile-card" data-article-id={article.id}>
                  {article.featured_image ? (
                    <div class="ftn-tile-image">
                      <img src={imageUrl} alt={article.title} loading="lazy" />
                    </div>
                  ) : (
                    <div class="ftn-tile-no-image">No Image</div>
                  )}
                  
                  <div class="ftn-tile-content">
                    <h3 class="ftn-tile-title">{article.title}</h3>
                    <span class={`ftn-tile-status ${statusClass}`}>{statusText}</span>
                    
                    <div class="ftn-tile-actions">
                      <a href={`/writer/edit/${article.id}`} class="ftn-tile-btn">Edit</a>
                      {article.status === 'approved' && (
                        <a href={`/news/articles/${article.slug}`} target="_blank" class="ftn-tile-btn view">View</a>
                      )}
                      <button 
                        type="button"
                        class="ftn-tile-btn delete"
                        data-delete-id={article.id}
                      >
                        Delete
                      </button>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>

  <script>
    // Use event delegation for delete buttons to avoid XSS
    document.addEventListener('click', async (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.matches('[data-delete-id]')) {
        const id = target.getAttribute('data-delete-id');
        if (!id) return;
        
        if (!confirm('Are you sure you want to delete this article?')) return;
        
        try {
          const response = await fetch(`/api/articles/${id}`, { method: 'DELETE' });
          if (response.ok) {
            // Remove the card from DOM
            const card = document.querySelector(`[data-article-id="${id}"]`);
            if (card) {
              card.remove();
            }
            alert('Article deleted');
          } else {
            alert('Failed to delete article');
          }
        } catch (error) {
          alert('Error deleting article');
        }
      }
    });
  </script>
</NewsLayout>
