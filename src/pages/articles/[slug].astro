---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getArticleBySlug } from '@/lib/db-utils';
import { getImageUrl } from '@/lib/db-utils';
import { marked } from 'marked';

// Constants for text limits
const MAX_SOCIAL_DESCRIPTION_LENGTH = 150;

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';

if (!slug) {
  return Astro.redirect('/');
}

// Fetch article from database
const article = await getArticleBySlug(db, slug);

// Check if article exists and is approved
if (!article || article.status !== 'approved') {
  return Astro.redirect('/');
}

// Configure marked to handle images properly
marked.use({
  renderer: {
    image({ href, title, text }) {
      // Use the helper function to construct proper image URL
      const imageUrl = getImageUrl(href, r2PublicUrl);
      const titleAttr = title ? ` title="${title}"` : '';
      return `<img src="${imageUrl || href}" alt="${text}"${titleAttr} />`;
    }
  }
});

// Parse markdown content
const htmlContent = marked.parse(article.content);

// Use the helper function to construct proper featured image URL
const imageUrl = getImageUrl(article.featured_image, r2PublicUrl);

const formattedDate = new Date(article.published_at || article.created_at).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Get author handle
const authorHandle = article.author_handle || '@fishtanklive';
const twitterUrl = authorHandle.startsWith('@') 
  ? `https://x.com/${authorHandle.substring(1)}` 
  : `https://x.com/${authorHandle}`;

// Description for social preview - use excerpt or first portion of cleaned content
const socialDescription = article.excerpt || 
  article.content?.substring(0, MAX_SOCIAL_DESCRIPTION_LENGTH).replace(/[#*_\[\]]/g, '') + '...';
---

<NewsLayout title={article.title} description={socialDescription} image={imageUrl}>
  <article class="ftn-article-detail">
    <h1>{article.title}</h1>

    <div class="ftn-article-byline">
      <span class="ftn-byline-item"><span class="ftn-byline-label">Written by:</span> <strong>{article.author_name}</strong></span>
      <span class="ftn-byline-sep">✦</span>
      <span class="ftn-byline-item"><span class="ftn-byline-label">Twitter:</span> <a href={twitterUrl} target="_blank" rel="noopener" class="ftn-byline-handle">{authorHandle}</a></span>
      <span class="ftn-byline-sep">✦</span>
      <span class="ftn-byline-item"><span class="ftn-byline-label">Date Published:</span> <strong>{formattedDate}</strong></span>
      {article.category && (
        <><span class="ftn-byline-sep">✦</span><span class="ftn-byline-item ftn-byline-category">{article.category.toUpperCase()}</span></>
      )}
    </div>

    {imageUrl && (
      <img src={imageUrl} alt={article.title} class="ftn-article-hero" />
    )}

    {article.excerpt && (
      <p class="ftn-article-subtitle">{article.excerpt}</p>
    )}

    <div class="ftn-article-body" set:html={htmlContent} />
  </article>
</NewsLayout>
