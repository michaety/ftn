---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getSession, getCookie, getArticles, getPendingUsers, getImageUrl } from '@/lib/db-utils';

// Check authentication
const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.SESSION;
const sessionId = getCookie(Astro.request, 'sessionId');
const session = await getSession(kv, sessionId);

if (!session || session.userRole !== 'admin') {
  return Astro.redirect('/login');
}

// Fetch all articles and pending users
const allArticles = await getArticles(db);
const pendingUsers = await getPendingUsers(db);
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';
---

<NewsLayout title="Admin Dashboard" role="admin" userName={session.userName}>
  <div class="ftn-container">
    <div class="ftn-dashboard">
      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Quick Actions</h2>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          <a href="/writer/new" class="ftn-btn">Create New Article</a>
          <a href="/admin/articles" class="ftn-btn">Manage All Articles</a>
          <a href="/admin/settings" class="ftn-btn">Trending Settings</a>
        </div>
      </div>

      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Recent Articles</h2>
        
        {allArticles.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">No articles yet. <a href="/writer/new" class="ftn-btn">Create your first article</a></p>
        ) : (
          <div class="ftn-tile-grid">
            {allArticles.slice(0, 8).map((article: any) => {
              const statusClass = article.status === 'approved' ? 'published' : 'draft';
              const statusText = article.status === 'approved' ? 'Published' : 'Draft';
              const imageUrl = getImageUrl(article.featured_image, r2PublicUrl) || article.featured_image;
              
              return (
                <article class="ftn-tile-card">
                  {article.featured_image ? (
                    <div class="ftn-tile-image">
                      <img src={imageUrl} alt={article.title} loading="lazy" />
                    </div>
                  ) : (
                    <div class="ftn-tile-no-image">No Image</div>
                  )}
                  
                  <div class="ftn-tile-content">
                    <h3 class="ftn-tile-title">{article.title}</h3>
                    <span class={`ftn-tile-status ${statusClass}`}>{statusText}</span>
                    
                    <div class="ftn-tile-actions">
                      <a href={`/writer/edit/${article.id}`} class="ftn-tile-btn">Edit</a>
                      {article.status === 'approved' && (
                        <a href={`/articles/${article.slug}`} target="_blank" class="ftn-tile-btn view">View</a>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>

      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Pending User Signups</h2>
        
        {pendingUsers.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">No pending signups.</p>
        ) : (
          <div style="overflow-x: auto;">
            <table style="width: 100%; background: white; border: 6px solid black; border-collapse: collapse;">
              <thead>
                <tr style="background: black; color: white;">
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Email</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Name</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Handle</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Registered</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Actions</th>
                </tr>
              </thead>
              <tbody>
                {pendingUsers.map((user: any) => (
                  <tr>
                    <td style="padding: 15px; border: 3px solid black; font-weight: bold;">{user.email}</td>
                    <td style="padding: 15px; border: 3px solid black;">{user.name}</td>
                    <td style="padding: 15px; border: 3px solid black;">{user.author_handle || 'N/A'}</td>
                    <td style="padding: 15px; border: 3px solid black;">{new Date(user.created_at).toLocaleDateString()}</td>
                    <td style="padding: 15px; border: 3px solid black;">
                      <div style="display: flex; gap: 10px;">
                        <button 
                          type="button"
                          class="ftn-btn ftn-btn-approve"
                          style="padding: 5px 10px;"
                          data-approve-id={user.id}
                        >
                          Approve
                        </button>
                        <button 
                          type="button"
                          class="ftn-btn ftn-btn-reject"
                          style="padding: 5px 10px;"
                          data-reject-id={user.id}
                        >
                          Reject
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </div>

  <script>
    // Use event delegation for user action buttons
    document.addEventListener('click', async (e: Event) => {
      const target = e.target as HTMLElement;
      
      // Handle approve button
      if (target.matches('[data-approve-id]')) {
        const id = target.getAttribute('data-approve-id');
        if (!id) return;
        
        try {
          const formData = new FormData();
          formData.append('userId', id);
          formData.append('action', 'approve');
          
          const response = await fetch('/api/admin/pending-users', { 
            method: 'POST',
            body: formData
          });
          
          if (response.ok) {
            alert('User approved! They can now login.');
            window.location.reload();
          } else {
            alert('Failed to approve user');
          }
        } catch (error) {
          alert('Error approving user');
        }
      }
      
      // Handle reject button
      if (target.matches('[data-reject-id]')) {
        const id = target.getAttribute('data-reject-id');
        if (!id) return;
        
        try {
          const formData = new FormData();
          formData.append('userId', id);
          formData.append('action', 'reject');
          
          const response = await fetch('/api/admin/pending-users', { 
            method: 'POST',
            body: formData
          });
          
          if (response.ok) {
            alert('User rejected');
            window.location.reload();
          } else {
            alert('Failed to reject user');
          }
        } catch (error) {
          alert('Error rejecting user');
        }
      }
    });
  </script>
</NewsLayout>
