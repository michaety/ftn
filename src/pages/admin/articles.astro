---
import '@/styles/news.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Articles - Fishtank News</title>
</head>
<body>
  <div id="app"></div>

  <script>
    // Pagination state
    let currentPage = 1;
    const pageSize = 20;
    let isLoading = false;
    let hasMoreArticles = true;
    let currentStatus = '';
    let allLoadedArticles: any[] = [];

    // Check authentication
    async function checkAuth() {
      try {
        const response = await fetch('/api/admin/users');
        if (!response.ok) {
          window.location.href = '/login';
          return null;
        }
        return true;
      } catch (error) {
        window.location.href = '/login';
        return null;
      }
    }

    async function loadPage() {
      const authenticated = await checkAuth();
      if (!authenticated) return;

      const app = document.getElementById('app');
      if (!app) return;
      
      app.innerHTML = `
        <header class="ftn-header">
          <div class="ftn-container">
            <div class="ftn-header-content">
              <a href="/admin" class="ftn-logo-link">
                <img src="/logo.webp" alt="Fishtank News" class="ftn-header-logo-img" />
              </a>
              <nav class="ftn-nav">
                <a href="/admin">Dashboard</a>
                <a href="/admin/articles">Articles</a>
                <a href="/writer/new">New Article</a>
                <button id="logoutBtn" class="ftn-logout-btn">Logout</button>
              </nav>
            </div>
          </div>
        </header>

        <main class="ftn-container">
          <div class="ftn-dashboard">
            <h1 class="ftn-dashboard-title">Manage Articles</h1>
            
            <div class="ftn-dashboard-section">
              <h2 class="ftn-section-title">Filter by Status</h2>
              <div style="display: flex; gap: 10px; margin-bottom: 30px; flex-wrap: wrap;">
                <button class="ftn-btn filter-btn" data-status="">All</button>
                <button class="ftn-btn filter-btn" data-status="draft">Draft</button>
                <button class="ftn-btn filter-btn" data-status="approved">Published</button>
              </div>
            </div>

            <div class="ftn-dashboard-section">
              <h2 class="ftn-section-title">Articles</h2>
              <div id="articles-list" class="ftn-tile-grid">
                <p class="ftn-loading-indicator">Loading...</p>
              </div>
            </div>
          </div>
        </main>

        <footer class="ftn-footer">
          <div class="ftn-container">
            <div class="ftn-footer-content">
              <p>&copy; ${new Date().getFullYear()} Fishtank News. All rights reserved.</p>
            </div>
          </div>
        </footer>
      `;

      // Setup logout
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/';
      });

      // Setup filter buttons
      const filterButtons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;
      filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          filterButtons.forEach(b => b.style.opacity = '0.5');
          btn.style.opacity = '1';
          // Reset pagination when filter changes
          currentPage = 1;
          hasMoreArticles = true;
          allLoadedArticles = [];
          currentStatus = btn.dataset.status || '';
          loadArticles(currentStatus, true);
        });
      });

      // Set initial filter
      filterButtons[0].style.opacity = '1';
      
      // Setup infinite scroll
      setupInfiniteScroll();
      
      // Setup event delegation for delete buttons
      setupDeleteHandlers();
      
      loadArticles('', true);
    }

    function setupInfiniteScroll() {
      window.addEventListener('scroll', () => {
        if (isLoading || !hasMoreArticles) return;
        
        const scrollHeight = document.documentElement.scrollHeight;
        const scrollTop = window.scrollY;
        const clientHeight = window.innerHeight;
        
        // Load more when user is 200px from bottom
        if (scrollTop + clientHeight >= scrollHeight - 200) {
          loadArticles(currentStatus, false);
        }
      });
    }

    function setupDeleteHandlers() {
      // Use event delegation for delete buttons to avoid XSS
      document.addEventListener('click', async (e: Event) => {
        const target = e.target as HTMLElement;
        if (target.matches('[data-delete-id]')) {
          const id = target.getAttribute('data-delete-id');
          if (!id) return;
          
          if (!confirm('Are you sure you want to delete this article? This action cannot be undone.')) return;
          
          try {
            const response = await fetch('/api/articles/' + id, { method: 'DELETE' });
            if (response.ok) {
              alert('Article deleted');
              // Reset and reload
              currentPage = 1;
              hasMoreArticles = true;
              allLoadedArticles = [];
              loadArticles(currentStatus, true);
            } else {
              alert('Failed to delete article');
            }
          } catch (error) {
            alert('Error deleting article');
          }
        }
      });
    }

    function escapeHtml(text: string): string {
      const escapeMap: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      };
      return text.replace(/[&<>"']/g, (char) => escapeMap[char] || char);
    }

    function sanitizeUrl(url: string): string {
      // Only allow http, https, and relative URLs
      if (!url) return '';
      const trimmed = url.trim();
      if (trimmed.startsWith('/') || trimmed.startsWith('http://') || trimmed.startsWith('https://')) {
        return trimmed;
      }
      // Assume it's a relative path if no protocol
      return trimmed;
    }

    function renderArticleCard(article: any) {
      const statusClass = article.status === 'approved' ? 'published' : 'draft';
      const statusText = article.status === 'approved' ? 'Published' : 'Draft';
      const safeTitle = escapeHtml(article.title || '');
      const safeSlug = encodeURIComponent(article.slug || '');
      const safeImage = article.featured_image ? sanitizeUrl(article.featured_image) : '';
      
      return `
        <article class="ftn-tile-card" data-article-id="${article.id}">
          ${safeImage ? `
            <div class="ftn-tile-image">
              <img src="${safeImage}" alt="${safeTitle}" loading="lazy" />
            </div>
          ` : `
            <div class="ftn-tile-no-image">No Image</div>
          `}
          
          <div class="ftn-tile-content">
            <h3 class="ftn-tile-title">${safeTitle}</h3>
            <span class="ftn-tile-status ${statusClass}">${statusText}</span>
            
            <div class="ftn-tile-actions">
              <a href="/writer/edit/${article.id}" class="ftn-tile-btn">Edit</a>
              ${article.status === 'approved' ? `
                <a href="/news/articles/${safeSlug}" target="_blank" class="ftn-tile-btn view">View</a>
              ` : ''}
              <button type="button" class="ftn-tile-btn delete" data-delete-id="${article.id}">Delete</button>
            </div>
          </div>
        </article>
      `;
    }

    async function loadArticles(status = '', reset = false) {
      if (isLoading) return;
      isLoading = true;
      
      const container = document.getElementById('articles-list');
      if (!container) return;
      
      if (reset) {
        container.innerHTML = '<p class="ftn-loading-indicator">Loading...</p>';
      } else {
        // Add loading indicator at the end
        const loadingEl = document.createElement('div');
        loadingEl.className = 'ftn-loading-indicator';
        loadingEl.id = 'scroll-loading';
        loadingEl.textContent = 'Loading more...';
        container.appendChild(loadingEl);
      }
      
      try {
        const url = status ? `/api/articles?status=${encodeURIComponent(status)}` : '/api/articles';
        const response = await fetch(url);
        const data = await response.json();
        
        // Remove scroll loading indicator
        const scrollLoading = document.getElementById('scroll-loading');
        if (scrollLoading) scrollLoading.remove();
        
        if (data.articles && data.articles.length > 0) {
          // Client-side pagination simulation
          const startIndex = (currentPage - 1) * pageSize;
          const endIndex = startIndex + pageSize;
          const pageArticles = data.articles.slice(startIndex, endIndex);
          
          if (pageArticles.length === 0) {
            hasMoreArticles = false;
            if (reset) {
              container.innerHTML = '<p class="ftn-loading-indicator">No articles found.</p>';
            }
          } else {
            if (reset) {
              allLoadedArticles = pageArticles;
              container.innerHTML = pageArticles.map(renderArticleCard).join('');
            } else {
              allLoadedArticles = [...allLoadedArticles, ...pageArticles];
              const newCardsHtml = pageArticles.map(renderArticleCard).join('');
              container.insertAdjacentHTML('beforeend', newCardsHtml);
            }
            
            // Check if there are more articles
            hasMoreArticles = endIndex < data.articles.length;
            currentPage++;
          }
        } else {
          if (reset) {
            container.innerHTML = '<p class="ftn-loading-indicator">No articles found.</p>';
          }
          hasMoreArticles = false;
        }
      } catch (error) {
        console.error('Error loading articles:', error);
        const scrollLoading = document.getElementById('scroll-loading');
        if (scrollLoading) scrollLoading.remove();
        
        if (reset) {
          container.innerHTML = '<p class="ftn-loading-indicator" style="color: red;">Error loading articles.</p>';
        }
      } finally {
        isLoading = false;
      }
    }

    loadPage();
  </script>
</body>
</html>
