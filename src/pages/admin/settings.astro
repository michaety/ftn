---
import '@/styles/news.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Trending Settings - Fishtank News</title>
</head>
<body>
  <div id="app"></div>

  <script>
    interface Article {
      id: number;
      title: string;
      slug: string;
    }

    interface TrendingSettings {
      mode: 'automatic' | 'manual';
      articleIds: number[];
    }

    let settings: TrendingSettings = { mode: 'automatic', articleIds: [] };
    let articles: Article[] = [];
    let selectedArticles: number[] = [];

    // Check authentication
    async function checkAuth(): Promise<boolean> {
      try {
        const response = await fetch('/api/admin/users');
        if (!response.ok) {
          window.location.href = '/login';
          return false;
        }
        return true;
      } catch (error) {
        window.location.href = '/login';
        return false;
      }
    }

    function escapeHtml(text: string): string {
      const escapeMap: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      };
      return text.replace(/[&<>"']/g, (char) => escapeMap[char] || char);
    }

    async function loadSettings(): Promise<void> {
      try {
        const response = await fetch('/api/admin/trending-settings');
        if (response.ok) {
          const data = await response.json();
          settings = data.settings;
          articles = data.articles;
          selectedArticles = [...settings.articleIds];
          renderPage();
        } else {
          console.error('Failed to load settings');
        }
      } catch (error) {
        console.error('Error loading settings:', error);
      }
    }

    async function saveSettings(): Promise<void> {
      try {
        const response = await fetch('/api/admin/trending-settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            mode: settings.mode,
            articleIds: selectedArticles
          })
        });

        if (response.ok) {
          const data = await response.json();
          settings = data.settings;
          alert('Settings saved successfully!');
        } else {
          const error = await response.json();
          alert('Failed to save settings: ' + (error.error || 'Unknown error'));
        }
      } catch (error) {
        console.error('Error saving settings:', error);
        alert('Error saving settings');
      }
    }

    function toggleArticle(id: number): void {
      const idx = selectedArticles.indexOf(id);
      if (idx > -1) {
        selectedArticles.splice(idx, 1);
      } else if (selectedArticles.length < 4) {
        selectedArticles.push(id);
      } else {
        alert('You can select up to 4 articles for Trending Now.');
        return;
      }
      renderPage();
    }

    function moveUp(idx: number): void {
      if (idx > 0) {
        [selectedArticles[idx - 1], selectedArticles[idx]] = [selectedArticles[idx], selectedArticles[idx - 1]];
        renderPage();
      }
    }

    function moveDown(idx: number): void {
      if (idx < selectedArticles.length - 1) {
        [selectedArticles[idx + 1], selectedArticles[idx]] = [selectedArticles[idx], selectedArticles[idx + 1]];
        renderPage();
      }
    }

    function removeFromSelected(id: number): void {
      selectedArticles = selectedArticles.filter(a => a !== id);
      renderPage();
    }

    function renderPage(): void {
      const app = document.getElementById('app');
      if (!app) return;

      const selectedArticlesList = selectedArticles.map((id, idx) => {
        const article = articles.find(a => a.id === id);
        if (!article) return '';
        return `
          <div class="selected-article" data-id="${article.id}">
            <span class="article-order">${idx + 1}</span>
            <span class="article-title">${escapeHtml(article.title)}</span>
            <div class="article-actions">
              <button type="button" class="move-btn" data-action="up" data-idx="${idx}" ${idx === 0 ? 'disabled' : ''}>↑</button>
              <button type="button" class="move-btn" data-action="down" data-idx="${idx}" ${idx === selectedArticles.length - 1 ? 'disabled' : ''}>↓</button>
              <button type="button" class="remove-btn" data-id="${article.id}">✕</button>
            </div>
          </div>
        `;
      }).join('');

      const availableArticlesList = articles
        .filter(a => !selectedArticles.includes(a.id))
        .map(article => `
          <div class="available-article" data-id="${article.id}">
            <span class="article-title">${escapeHtml(article.title)}</span>
            <button type="button" class="add-btn" data-id="${article.id}">+ Add</button>
          </div>
        `).join('');

      app.innerHTML = `
        <header class="ftn-header">
          <div class="ftn-container">
            <div class="ftn-header-content">
              <a href="/admin" class="ftn-logo-link">
                <img src="/logo.webp" alt="Fishtank News" class="ftn-header-logo-img" />
              </a>
              <nav class="ftn-nav">
                <a href="/admin">Dashboard</a>
                <a href="/admin/articles">Articles</a>
                <a href="/admin/settings">Settings</a>
                <a href="/writer/new">New Article</a>
                <button id="logoutBtn" class="ftn-logout-btn">Logout</button>
              </nav>
            </div>
          </div>
        </header>

        <main class="ftn-container">
          <div class="ftn-dashboard">
            <h1 class="ftn-dashboard-title">Trending Now Settings</h1>
            
            <div class="ftn-dashboard-section">
              <h2 class="ftn-section-title">Selection Mode</h2>
              <div class="mode-toggle">
                <label class="mode-option ${settings.mode === 'automatic' ? 'active' : ''}">
                  <input type="radio" name="mode" value="automatic" ${settings.mode === 'automatic' ? 'checked' : ''} />
                  <span class="mode-label">Automatic</span>
                  <span class="mode-desc">Display articles based on highest view count</span>
                </label>
                <label class="mode-option ${settings.mode === 'manual' ? 'active' : ''}">
                  <input type="radio" name="mode" value="manual" ${settings.mode === 'manual' ? 'checked' : ''} />
                  <span class="mode-label">Manual</span>
                  <span class="mode-desc">Select up to 4 articles to display</span>
                </label>
              </div>
            </div>

            <div class="ftn-dashboard-section manual-section" style="${settings.mode === 'manual' ? '' : 'opacity: 0.5; pointer-events: none;'}">
              <h2 class="ftn-section-title">Selected Articles (${selectedArticles.length}/4)</h2>
              <div class="selected-articles-list">
                ${selectedArticlesList || '<p class="no-articles">No articles selected. Add articles from below.</p>'}
              </div>
            </div>

            <div class="ftn-dashboard-section manual-section" style="${settings.mode === 'manual' ? '' : 'opacity: 0.5; pointer-events: none;'}">
              <h2 class="ftn-section-title">Available Articles</h2>
              <div class="available-articles-list">
                ${availableArticlesList || '<p class="no-articles">No articles available.</p>'}
              </div>
            </div>

            <div class="ftn-dashboard-section">
              <button id="saveBtn" class="ftn-btn">Save Settings</button>
            </div>
          </div>
        </main>

        <footer class="ftn-footer">
          <div class="ftn-container">
            <div class="ftn-footer-content">
              <p>&copy; ${new Date().getFullYear()} Fishtank News. All rights reserved.</p>
            </div>
          </div>
        </footer>

        <style>
          .ftn-dashboard {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
          }
          
          .ftn-dashboard-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5em;
            font-weight: 900;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 30px;
            letter-spacing: 2px;
            border-bottom: 3px double var(--ink-black);
            padding-bottom: 15px;
          }
          
          .ftn-dashboard-section {
            background: var(--paper-white);
            border: 2px solid var(--ink-black);
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 3px 3px 0px rgba(0,0,0,0.1);
          }
          
          .ftn-section-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.4em;
            font-weight: 700;
            margin: 0 0 20px 0;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--aged-sepia);
          }
          
          .mode-toggle {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
          }
          
          .mode-option {
            flex: 1;
            min-width: 200px;
            padding: 20px;
            border: 2px solid var(--ink-black);
            cursor: pointer;
            transition: all 0.2s ease;
            background: var(--beige-bg);
          }
          
          .mode-option:hover {
            background: var(--paper-white);
          }
          
          .mode-option.active {
            background: var(--ink-black);
            color: var(--paper-white);
          }
          
          .mode-option input {
            display: none;
          }
          
          .mode-label {
            font-family: 'Playfair Display', serif;
            font-size: 1.2em;
            font-weight: 700;
            display: block;
            margin-bottom: 5px;
          }
          
          .mode-desc {
            font-size: 0.9em;
            opacity: 0.8;
          }
          
          .selected-articles-list,
          .available-articles-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 400px;
            overflow-y: auto;
          }
          
          .selected-article,
          .available-article {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            border: 2px solid var(--ink-black);
            background: var(--beige-bg);
          }
          
          .article-order {
            font-family: 'Playfair Display', serif;
            font-size: 1.2em;
            font-weight: 900;
            min-width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--ink-black);
            color: var(--paper-white);
          }
          
          .article-title {
            flex: 1;
            font-weight: 600;
          }
          
          .article-actions {
            display: flex;
            gap: 5px;
          }
          
          .move-btn,
          .remove-btn,
          .add-btn {
            padding: 5px 10px;
            border: 2px solid var(--ink-black);
            background: var(--paper-white);
            cursor: pointer;
            font-family: Georgia, serif;
            font-weight: 600;
            transition: all 0.2s ease;
          }
          
          .move-btn:hover:not(:disabled),
          .add-btn:hover {
            background: var(--ink-black);
            color: var(--paper-white);
          }
          
          .move-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
          }
          
          .remove-btn {
            background: #dc3545;
            color: white;
            border-color: #dc3545;
          }
          
          .remove-btn:hover {
            background: #c82333;
          }
          
          .add-btn {
            background: var(--aged-sepia);
            color: white;
            border-color: var(--aged-sepia);
          }
          
          .no-articles {
            text-align: center;
            color: var(--aged-sepia);
            font-style: italic;
            padding: 20px;
          }
          
          #saveBtn {
            width: 100%;
            padding: 15px;
            font-size: 1.1em;
          }
        </style>
      `;

      // Setup event listeners
      setupEventListeners();
    }

    function setupEventListeners(): void {
      // Logout button
      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/';
      });

      // Mode toggle
      document.querySelectorAll('input[name="mode"]').forEach(input => {
        input.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          settings.mode = target.value as 'automatic' | 'manual';
          renderPage();
        });
      });

      // Add buttons
      document.querySelectorAll('.add-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = parseInt((e.target as HTMLElement).getAttribute('data-id') || '0');
          if (id) toggleArticle(id);
        });
      });

      // Remove buttons
      document.querySelectorAll('.remove-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = parseInt((e.target as HTMLElement).getAttribute('data-id') || '0');
          if (id) removeFromSelected(id);
        });
      });

      // Move buttons
      document.querySelectorAll('.move-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const action = (e.target as HTMLElement).getAttribute('data-action');
          const idx = parseInt((e.target as HTMLElement).getAttribute('data-idx') || '0');
          if (action === 'up') moveUp(idx);
          else if (action === 'down') moveDown(idx);
        });
      });

      // Save button
      document.getElementById('saveBtn')?.addEventListener('click', saveSettings);
    }

    async function init(): Promise<void> {
      const authenticated = await checkAuth();
      if (!authenticated) return;
      await loadSettings();
    }

    init();
  </script>
</body>
</html>
