---
import NewsLayout from '@/layouts/NewsLayout.astro';
import NewsArticleCard from '@/components/news/NewsArticleCard.astro';
import { getArticles, getTrendingArticles } from '@/lib/db-utils';

const db = Astro.locals.runtime.env.DB;
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';

// Fetch approved articles from the database
const articles = await getArticles(db, 'approved');

// Fetch trending articles (up to 4, supports both automatic and manual modes)
const trendingArticles = await getTrendingArticles(db, 4);
---

<NewsLayout title="Home" hideNavigation={true}>
  <div class="container ftn-container">
    <!-- Left Sidebar -->
    <aside class="sidebar ftn-sidebar left">
      <h3>Latest Updates</h3>
      <ul>
        <li><a href="https://www.fishtank.live/apply" target="_blank" rel="noopener"><strong>Season 5 applications open. Apply now!</strong></a></li>
      </ul>
      
      <h3>Trending Now</h3>
      {trendingArticles.length > 0 ? (
        <ul>
          {trendingArticles.map((article: any) => (
            <li>
              <a href={`/article/${article.slug}`}>{article.title}</a>
            </li>
          ))}
        </ul>
      ) : (
        <p style="font-size: 0.85em; color: var(--aged-sepia, #8B7355);">No trending articles yet.</p>
      )}
      
      <div class="x-embed" id="list-gif-embed">
        <h3>Community Updates</h3>
        <p style="font-size: 0.85em; margin-bottom: 10px;">See what the community has to say:</p>
        <div class="list-gif-container" style="text-align: center;">
          <a href="https://twitter.com/5wcol/lists/1712083470296686731" target="_blank" rel="noopener">
            <img src="/list.gif" alt="Community X List" style="width: 100%; max-width: 100%; border: 2px solid var(--ink-black, #000); box-shadow: 2px 2px 0px rgba(0,0,0,0.1);" />
          </a>
          <a href="https://twitter.com/5wcol/lists/1712083470296686731" target="_blank" rel="noopener" class="add-now-link" style="display: block; margin-top: 10px; color: var(--aged-sepia, #8B7355); text-decoration: underline; font-weight: bold; font-size: 1.1em;">add now!</a>
        </div>
      </div>
    </aside>

    <!-- Main Feed -->
    <main class="main-feed ftn-main-feed">
      <div class="filters ftn-filters">
        <button class="active" data-filter="all">All</button>
        <button data-filter="breaking">Breaking</button>
        <button data-filter="rumor">Rumors</button>
        <button data-filter="opinion">Opinions</button>
        <button data-filter="fake-news">Fake News</button>
      </div>

      {articles.length === 0 ? (
        <p style="text-align: center; padding: 40px 0;">No articles published yet.</p>
      ) : (
        articles.map((article, index) => (
          <NewsArticleCard article={article} r2PublicUrl={r2PublicUrl} index={index} />
        ))
      )}
    </main>

    <!-- Right Sidebar -->
    <aside class="sidebar ftn-sidebar right">
      <h3>Socials & Links</h3>
      <ul>
        <li><a href="https://www.fishtank.live/" target="_blank" rel="noopener">Fishtank.live</a></li>
        <li><a href="https://www.fishtank.live/shop" target="_blank" rel="noopener">Fishtank Merch</a></li>
        <li><a href="https://x.com/fishtankislive" target="_blank" rel="noopener">Official X</a></li>
        <li><a href="https://www.tiktok.com/@fishtank.live.clips" target="_blank" rel="noopener">Official TikTok</a></li>
        <li><a href="https://www.instagram.com/fishtank.live" target="_blank" rel="noopener">Official Instagram</a></li>
        <li><a href="https://www.youtube.com/@fishtankislive" target="_blank" rel="noopener">Official YouTube</a></li>
      </ul>
      <div class="x-embed" id="fishtank-profile-card">
        <h3>Official Feed</h3>
        <div class="fishtank-profile-card" style="text-align: center; padding: 20px; background: var(--paper-white, #fdfaf5); border: 2px solid var(--ink-black, #000); box-shadow: 2px 2px 0px rgba(0,0,0,0.1);">
          <a href="https://x.com/fishtankislive" target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
            <img src="https://pbs.twimg.com/profile_images/1857847802824658944/vFKwMQs4_400x400.jpg" alt="Fishtank Live Profile" style="width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--ink-black, #000); display: block; margin: 0 auto 15px auto; object-fit: cover;" />
            <p style="margin: 0 0 5px 0; font-size: 1.2em; font-weight: bold; color: var(--ink-black, #000);">Fishtank Live</p>
            <p style="margin: 0 0 15px 0; font-size: 0.9em; color: var(--aged-sepia, #8B7355);">@fishtankislive</p>
          </a>
          <a href="https://x.com/fishtankislive" target="_blank" rel="noopener" class="ftn-btn" style="display: inline-block; padding: 12px 24px; background-color: var(--ink-black, #000); color: var(--paper-white, #fff); text-decoration: none; font-weight: bold; border: 2px solid var(--ink-black, #000); transition: all 0.3s ease;">Follow on X</a>
        </div>
      </div>
    </aside>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const buttons = document.querySelectorAll('.filters button, .ftn-filters button');
      const articles = document.querySelectorAll('.article, .ftn-article-card');

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-filter');
          buttons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');

          articles.forEach((article, index) => {
            if (article.classList.contains(filter) || filter === 'all') {
              article.classList.remove('hidden');
              article.style.setProperty('--index', index.toString());
            } else {
              article.classList.add('hidden');
            }
          });
        });
      });

      // Note: Sidebar responsive behavior is now handled entirely by CSS media queries
      // in news.css. No JavaScript manipulation of sidebar styles is needed.
    });
  </script>
</NewsLayout>
