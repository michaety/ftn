---
import MainLayout from '@/layouts/MainLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getArticles } from '@/lib/db-utils';

const db = Astro.locals.runtime.env.DB;
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';

// Fetch approved articles from the database
const articles = await getArticles(db, 'approved');

// Separate featured article (first one) from the rest
const featuredArticle = articles.length > 0 ? articles[0] : null;
const regularArticles = articles.slice(1);
---

<MainLayout title="Home">
  <Header role="public" />
  <main>
    <div class="ftn-container">
      <h1 class="ftn-page-title">Latest News</h1>
      
      {articles.length === 0 ? (
        <p style="text-align: center; padding: 40px 0; font-size: 1.2rem;">No articles published yet.</p>
      ) : (
        <div class="ftn-articles-grid">
          {/* Featured Article - Full Width */}
          {featuredArticle && (
            <div class="ftn-featured-article">
              <ArticleCard article={featuredArticle} r2PublicUrl={r2PublicUrl} featured={true} />
            </div>
          )}
          
          {/* Regular Articles Grid */}
          {regularArticles.map((article) => (
            <ArticleCard article={article} r2PublicUrl={r2PublicUrl} />
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</MainLayout>
