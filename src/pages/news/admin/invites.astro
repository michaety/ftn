---
import '@/styles/news.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Invites - Fishtank News</title>
</head>
<body>
  <div id="app"></div>

  <script>
    // Check authentication
    async function checkAuth() {
      try {
        const response = await fetch('/api/admin/users');
        if (!response.ok) {
          window.location.href = '/login';
          return null;
        }
        return true;
      } catch (error) {
        window.location.href = '/login';
        return null;
      }
    }

    async function loadPage() {
      const authenticated = await checkAuth();
      if (!authenticated) return;

      const app = document.getElementById('app');
      
      app.innerHTML = `
        <header class="ftn-header">
          <div class="ftn-container">
            <div class="ftn-header-content">
              <h1 class="ftn-logo">
                <a href="/news/admin">FISHTANK NEWS - ADMIN</a>
              </h1>
              <nav class="ftn-nav">
                <a href="/news/admin">Dashboard</a>
                <a href="/news/admin/articles">Articles</a>
                <a href="/news/admin/invites">Invites</a>
                <button id="logoutBtn" class="ftn-logout-btn">Logout</button>
              </nav>
            </div>
          </div>
        </header>

        <main class="ftn-container">
          <div class="ftn-dashboard">
            <h1 class="ftn-dashboard-title">Manage Invites</h1>
            
            <div class="ftn-dashboard-section">
              <h2 class="ftn-section-title">Send New Invite</h2>
              <form id="inviteForm" style="background: white; border: 6px solid black; padding: 40px; margin: 40px 0;">
                <div class="ftn-form-group">
                  <label for="email" class="ftn-label">Email Address</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    class="ftn-input"
                    placeholder="editor@example.com"
                    required
                  />
                </div>

                <div id="inviteError" class="ftn-error" style="display: none;"></div>
                <div id="inviteSuccess" class="ftn-success" style="display: none;"></div>

                <button type="submit" class="ftn-btn" style="margin-top: 20px;">
                  Send Invite
                </button>
              </form>
            </div>

            <div class="ftn-dashboard-section">
              <h2 class="ftn-section-title">All Invites</h2>
              <div id="invites-list" style="margin: 40px 0;">
                <p>Loading...</p>
              </div>
            </div>
          </div>
        </main>

        <footer class="ftn-footer">
          <div class="ftn-container">
            <div class="ftn-footer-content">
              <p>&copy; ${new Date().getFullYear()} Fishtank News. All rights reserved.</p>
            </div>
          </div>
        </footer>
      `;

      // Setup logout
      document.getElementById('logoutBtn').addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/';
      });

      // Setup invite form
      const inviteForm = document.getElementById('inviteForm');
      const inviteError = document.getElementById('inviteError');
      const inviteSuccess = document.getElementById('inviteSuccess');

      inviteForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        inviteError.style.display = 'none';
        inviteSuccess.style.display = 'none';

        const formData = new FormData(inviteForm);

        try {
          const response = await fetch('/api/admin/invites', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();

          if (response.ok) {
            const inviteUrl = window.location.origin + '/signup?token=' + data.invite.token;
            inviteSuccess.innerHTML = 
              'Invite sent successfully!<br>' +
              '<strong>Invite Link:</strong><br>' +
              '<input type="text" value="' + inviteUrl + '" ' +
              'style="width: 100%; padding: 10px; margin-top: 10px; font-family: \'Courier New\', monospace;" ' +
              'readonly onclick="this.select()" />' +
              '<br>' +
              '<small>Share this link with the editor. It expires in 7 days.</small>';
            inviteSuccess.style.display = 'block';
            inviteForm.reset();
            loadInvites(); // Refresh the list
          } else {
            inviteError.textContent = data.error || 'Failed to create invite';
            inviteError.style.display = 'block';
          }
        } catch (error) {
          inviteError.textContent = 'An error occurred. Please try again.';
          inviteError.style.display = 'block';
        }
      });

      // Load invites
      loadInvites();
    }

    async function loadInvites() {
      const container = document.getElementById('invites-list');
      
      try {
        const response = await fetch('/api/admin/invites');
        const data = await response.json();
        
        if (data.invites && data.invites.length > 0) {
          const invitesTable = `
            <div style="overflow-x: auto;">
              <table style="width: 100%; background: white; border: 6px solid black; border-collapse: collapse;">
                <thead>
                  <tr style="background: black; color: white;">
                    <th style="padding: 15px; text-align: left; border: 3px solid black;">Email</th>
                    <th style="padding: 15px; text-align: left; border: 3px solid black;">Status</th>
                    <th style="padding: 15px; text-align: left; border: 3px solid black;">Created</th>
                    <th style="padding: 15px; text-align: left; border: 3px solid black;">Expires</th>
                    <th style="padding: 15px; text-align: left; border: 3px solid black;">Created By</th>
                  </tr>
                </thead>
                <tbody>
                  ${data.invites.map(invite => {
                    const isExpired = new Date(invite.expires_at) < new Date();
                    const statusText = invite.used ? 'USED' : (isExpired ? 'EXPIRED' : 'ACTIVE');
                    const statusColor = invite.used ? 'green' : (isExpired ? 'red' : 'blue');
                    
                    return `
                      <tr>
                        <td style="padding: 15px; border: 3px solid black; font-weight: bold;">${invite.email}</td>
                        <td style="padding: 15px; border: 3px solid black; color: ${statusColor}; font-weight: bold;">${statusText}</td>
                        <td style="padding: 15px; border: 3px solid black;">${new Date(invite.created_at).toLocaleString()}</td>
                        <td style="padding: 15px; border: 3px solid black;">${new Date(invite.expires_at).toLocaleString()}</td>
                        <td style="padding: 15px; border: 3px solid black;">${invite.created_by_name || 'Unknown'}</td>
                      </tr>
                    `;
                  }).join('')}
                </tbody>
              </table>
            </div>
          `;
          container.innerHTML = invitesTable;
        } else {
          container.innerHTML = '<p style="background: white; border: 6px solid black; padding: 40px; text-align: center;">No invites yet.</p>';
        }
      } catch (error) {
        console.error('Error loading invites:', error);
        container.innerHTML = '<p style="color: red;">Error loading invites.</p>';
      }
    }

    loadPage();
  </script>
</body>
</html>
