---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getSession, getCookie, getArticles, getPendingUsers } from '@/lib/db-utils';

// Check authentication
const db = Astro.locals.runtime.env.DB;
const kv = Astro.locals.runtime.env.SESSION;
const sessionId = getCookie(Astro.request, 'sessionId');
const session = await getSession(kv, sessionId);

if (!session || session.userRole !== 'admin') {
  return Astro.redirect('/login');
}

// Fetch pending articles and users
const pendingArticles = await getArticles(db, 'pending');
const pendingUsers = await getPendingUsers(db);
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';
---

<NewsLayout title="Admin Dashboard" role="admin" userName={session.userName}>
  <div class="ftn-container">
    <div class="ftn-dashboard">
      <h1 class="ftn-dashboard-title">Admin Dashboard</h1>
      
      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Pending Articles</h2>
        
        {pendingArticles.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">No pending articles.</p>
        ) : (
          <div class="ftn-grid">
            {pendingArticles.map((article: any) => (
              <article class="ftn-article-card">
                {article.featured_image && (
                  <div class="ftn-article-image">
                    <img 
                      src={article.featured_image.startsWith('http') ? article.featured_image : r2PublicUrl ? `${r2PublicUrl}/${article.featured_image}` : article.featured_image} 
                      alt={article.title} 
                    />
                  </div>
                )}
                
                <div class="ftn-article-content">
                  <h2 class="ftn-article-title">{article.title}</h2>
                  
                  {article.excerpt && (
                    <p class="ftn-article-excerpt">{article.excerpt}</p>
                  )}
                  
                  <div class="ftn-article-meta">
                    <span class="ftn-article-author">By {article.author_name}</span>
                    <span class="ftn-article-date">
                      {new Date(article.created_at).toLocaleDateString()}
                    </span>
                  </div>

                  <div class="ftn-article-actions">
                    <button 
                      onclick={`approveArticle(${article.id})`} 
                      class="ftn-btn ftn-btn-approve"
                    >
                      Approve
                    </button>
                    <button 
                      onclick={`rejectArticle(${article.id})`} 
                      class="ftn-btn ftn-btn-reject"
                    >
                      Reject
                    </button>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>

      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Pending User Signups</h2>
        
        {pendingUsers.length === 0 ? (
          <p style="text-align: center; padding: 40px 0;">No pending signups.</p>
        ) : (
          <div style="overflow-x: auto;">
            <table style="width: 100%; background: white; border: 6px solid black; border-collapse: collapse;">
              <thead>
                <tr style="background: black; color: white;">
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Email</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Name</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Handle</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Registered</th>
                  <th style="padding: 15px; text-align: left; border: 3px solid black;">Actions</th>
                </tr>
              </thead>
              <tbody>
                {pendingUsers.map((user: any) => (
                  <tr>
                    <td style="padding: 15px; border: 3px solid black; font-weight: bold;">{user.email}</td>
                    <td style="padding: 15px; border: 3px solid black;">{user.name}</td>
                    <td style="padding: 15px; border: 3px solid black;">{user.author_handle || 'N/A'}</td>
                    <td style="padding: 15px; border: 3px solid black;">{new Date(user.created_at).toLocaleDateString()}</td>
                    <td style="padding: 15px; border: 3px solid black;">
                      <div style="display: flex; gap: 10px;">
                        <button 
                          onclick={`approveUser(${user.id})`} 
                          class="ftn-btn ftn-btn-approve"
                          style="padding: 5px 10px;"
                        >
                          Approve
                        </button>
                        <button 
                          onclick={`rejectUser(${user.id})`} 
                          class="ftn-btn ftn-btn-reject"
                          style="padding: 5px 10px;"
                        >
                          Reject
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <div class="ftn-dashboard-section">
        <h2 class="ftn-section-title">Quick Actions</h2>
        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
          <a href="/news/admin" class="ftn-btn">Manage All Articles</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    (window as any).approveArticle = async (id: number) => {
      try {
        const response = await fetch(`/api/articles/${id}/approve`, { method: 'POST' });
        if (response.ok) {
          alert('Article approved!');
          window.location.reload();
        } else {
          alert('Failed to approve article');
        }
      } catch (error) {
        alert('Error approving article');
      }
    };

    (window as any).rejectArticle = async (id: number) => {
      try {
        const response = await fetch(`/api/articles/${id}/reject`, { method: 'POST' });
        if (response.ok) {
          alert('Article rejected');
          window.location.reload();
        } else {
          alert('Failed to reject article');
        }
      } catch (error) {
        alert('Error rejecting article');
      }
    };

    (window as any).approveUser = async (id: number) => {
      try {
        const formData = new FormData();
        formData.append('userId', id.toString());
        formData.append('action', 'approve');
        
        const response = await fetch('/api/admin/pending-users', { 
          method: 'POST',
          body: formData
        });
        
        if (response.ok) {
          alert('User approved! They can now login.');
          window.location.reload();
        } else {
          alert('Failed to approve user');
        }
      } catch (error) {
        alert('Error approving user');
      }
    };

    (window as any).rejectUser = async (id: number) => {
      try {
        const formData = new FormData();
        formData.append('userId', id.toString());
        formData.append('action', 'reject');
        
        const response = await fetch('/api/admin/pending-users', { 
          method: 'POST',
          body: formData
        });
        
        if (response.ok) {
          alert('User rejected');
          window.location.reload();
        } else {
          alert('Failed to reject user');
        }
      } catch (error) {
        alert('Error rejecting user');
      }
    };
  </script>
</NewsLayout>
