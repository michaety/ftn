---
import NewsLayout from '@/layouts/NewsLayout.astro';
import { getSession, getCookie } from '@/lib/db-utils';

// Check authentication
const kv = Astro.locals.runtime.env.SESSION;
const sessionId = getCookie(Astro.request, 'sessionId');
const session = await getSession(kv, sessionId);

if (!session || !['admin', 'editor'].includes(session.userRole)) {
  return Astro.redirect('/login');
}
---

<NewsLayout title="Create New Article" role="editor" userName={session.userName}>
  <div class="ftn-container">
    <div class="ftn-dashboard">
      <h1 class="ftn-dashboard-title">Create New Article</h1>
      
      <form id="articleForm" style="background: white; border: 6px solid black; padding: 40px; margin: 40px 0;">
        <div class="ftn-form-group">
          <label for="title" class="ftn-label">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            class="ftn-input"
            required
          />
        </div>

        <div class="ftn-form-group">
          <label for="excerpt" class="ftn-label">Excerpt (Optional)</label>
          <textarea
            id="excerpt"
            name="excerpt"
            class="ftn-textarea"
            rows="3"
            placeholder="Brief summary of the article..."
          ></textarea>
        </div>

        <div class="ftn-form-group">
          <label for="featured_image" class="ftn-label">Featured Image URL (Optional)</label>
          <input
            type="text"
            id="featured_image"
            name="featured_image"
            class="ftn-input"
            placeholder="/api/media/uploads/..."
          />
          <div style="margin-top: 10px;">
            <input type="file" id="imageUpload" accept="image/*" style="display: none;" />
            <button type="button" id="uploadImageBtn" class="ftn-btn" style="margin-right: 10px;">
              Upload Image
            </button>
            <span id="uploadStatus"></span>
          </div>
        </div>

        <div class="ftn-form-group">
          <label for="content" class="ftn-label">Content (Markdown)</label>
          
          <div class="ftn-markdown-editor">
            <div class="ftn-markdown-toolbar">
              <button type="button" data-markdown="# " class="ftn-toolbar-btn" title="Heading">H1</button>
              <button type="button" data-markdown="## " class="ftn-toolbar-btn" title="Heading 2">H2</button>
              <button type="button" data-markdown-wrap="**" class="ftn-toolbar-btn" title="Bold"><strong>B</strong></button>
              <button type="button" data-markdown-wrap="*" class="ftn-toolbar-btn" title="Italic"><em>I</em></button>
              <button type="button" data-markdown="[](url)" class="ftn-toolbar-btn" title="Link">Link</button>
              <button type="button" data-markdown-wrap="```&#10;" data-markdown-after="&#10;```" class="ftn-toolbar-btn" title="Code Block">Code</button>
              <button type="button" data-markdown="- " class="ftn-toolbar-btn" title="List">List</button>
              <button type="button" id="insertImageBtn" class="ftn-toolbar-btn" title="Insert Image">Image</button>
            </div>
            
            <textarea
              id="content"
              name="content"
              class="ftn-markdown-textarea"
              placeholder="Write your article in Markdown..."
              rows="20"
              required
            ></textarea>
            
            <div class="ftn-markdown-help">
              <p>
                <strong>Markdown Tips:</strong> Use # for headings, ** for bold, * for italic, 
                [text](url) for links, and ![alt](url) for images.
              </p>
            </div>
          </div>
        </div>

        <div class="ftn-form-group">
          <label for="category" class="ftn-label">Category *</label>
          <select id="category" name="category" class="ftn-input" required>
            <option value="">Select a category...</option>
            <option value="breaking">Breaking</option>
            <option value="rumor">Rumor</option>
            <option value="opinion">Opinion</option>
            <option value="fake news">Fake News</option>
          </select>
        </div>

        <div class="ftn-form-group">
          <label for="status" class="ftn-label">Status</label>
          <select id="status" name="status" class="ftn-input">
            <option value="draft">Draft</option>
            <option value="pending">Submit for Review</option>
          </select>
        </div>

        <div id="error" class="ftn-error" style="display: none;"></div>
        <div id="success" class="ftn-success" style="display: none;"></div>

        <div style="display: flex; gap: 10px; margin-top: 30px;">
          <button type="submit" class="ftn-btn">Save Article</button>
          <a href="/news/editor" class="ftn-btn" style="background: gray;">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('articleForm') as HTMLFormElement;
    const errorDiv = document.getElementById('error')!;
    const successDiv = document.getElementById('success')!;
    const contentTextarea = document.getElementById('content') as HTMLTextAreaElement;
    const imageUploadInput = document.getElementById('imageUpload') as HTMLInputElement;
    const uploadImageBtn = document.getElementById('uploadImageBtn') as HTMLButtonElement;
    const insertImageBtn = document.getElementById('insertImageBtn')!;
    const uploadStatus = document.getElementById('uploadStatus')!;
    const featuredImageInput = document.getElementById('featured_image') as HTMLInputElement;

    // Markdown toolbar handlers
    document.querySelectorAll('[data-markdown]').forEach(btn => {
      btn.addEventListener('click', () => {
        const markdown = (btn as HTMLElement).dataset.markdown!;
        insertAtCursor(contentTextarea, markdown);
      });
    });

    document.querySelectorAll('[data-markdown-wrap]').forEach(btn => {
      btn.addEventListener('click', () => {
        const before = (btn as HTMLElement).dataset.markdownWrap!;
        const after = (btn as HTMLElement).dataset.markdownAfter || before;
        wrapSelection(contentTextarea, before, after);
      });
    });

    function insertAtCursor(textarea: HTMLTextAreaElement, text: string) {
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const value = textarea.value;
      textarea.value = value.substring(0, start) + text + value.substring(end);
      textarea.focus();
      textarea.setSelectionRange(start + text.length, start + text.length);
    }

    function wrapSelection(textarea: HTMLTextAreaElement, before: string, after: string) {
      const start = textarea.selectionStart;
      const end = textarea.selectionEnd;
      const selectedText = textarea.value.substring(start, end);
      const value = textarea.value;
      textarea.value = value.substring(0, start) + before + selectedText + after + value.substring(end);
      textarea.focus();
      textarea.setSelectionRange(start + before.length, start + before.length + selectedText.length);
    }

    // Image upload
    uploadImageBtn.addEventListener('click', () => {
      imageUploadInput.click();
    });

    imageUploadInput.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      uploadStatus.textContent = 'Uploading...';
      uploadImageBtn.disabled = true;

      try {
        const formData = new FormData();
        formData.append('file', file);

        const response = await fetch('/api/media/upload', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          featuredImageInput.value = data.url;
          uploadStatus.textContent = 'Image uploaded successfully!';
          uploadStatus.style.color = 'green';
        } else {
          uploadStatus.textContent = 'Upload failed: ' + (data.error || 'Unknown error');
          uploadStatus.style.color = 'red';
        }
      } catch (error) {
        uploadStatus.textContent = 'Upload error: ' + (error as Error).message;
        uploadStatus.style.color = 'red';
      } finally {
        uploadImageBtn.disabled = false;
        imageUploadInput.value = '';
      }
    });

    insertImageBtn.addEventListener('click', () => {
      const url = prompt('Enter image URL:');
      if (url) {
        insertAtCursor(contentTextarea, `![Image](${url})`);
      }
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      errorDiv.style.display = 'none';
      successDiv.style.display = 'none';

      const formData = new FormData(form);

      try {
        const response = await fetch('/api/articles', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          successDiv.textContent = 'Article saved successfully!';
          successDiv.style.display = 'block';
          
          setTimeout(() => {
            window.location.href = '/news/editor';
          }, 1500);
        } else {
          errorDiv.textContent = data.error || 'Failed to save article';
          errorDiv.style.display = 'block';
        }
      } catch (error) {
        errorDiv.textContent = 'An error occurred. Please try again.';
        errorDiv.style.display = 'block';
      }
    });
  </script>
</NewsLayout>
