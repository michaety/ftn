---
interface Props {
  currentPath?: string;
  role?: 'public' | 'admin' | 'editor';
  userName?: string;
  hideNavigation?: boolean;
}

const { currentPath = '', role = 'public', userName, hideNavigation = false } = Astro.props;

// Get current date for subtitle
const currentDate = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Determine if we should show the logo image (for admin/editor pages)
const showLogoImage = role === 'admin' || role === 'editor';
---

<header class="ftn-header">
  <a href="/" class="ftn-logo-link">
    {showLogoImage ? (
      <img src="/logo.webp" alt="Fishtank News" class="ftn-header-logo-always" />
    ) : (
      <h1 class="ftn-logo">
        <span class="ftn-logo-text">Fishtank.news</span>
        <img src="/logo.webp" alt="Fishtank News" class="ftn-logo-img" />
      </h1>
    )}
  </a>
  <p class="ftn-header-subtitle">
    Vol. 1, No. 1 ★ The Unofficial Source for Fishtank Updates ★ {currentDate}
  </p>
  {!hideNavigation && (
    <div class="ftn-header-content">
      <nav class="ftn-nav">
        {role === 'public' ? (
          <></>
        ) : role === 'admin' ? (
          <>
            <a href="/admin">Dashboard</a>
            <a href="/admin/articles">Articles</a>
            <a href="/writer/new">New Article</a>
            {userName && <span class="ftn-user">{userName}</span>}
            <button id="logoutBtn" class="ftn-logout-btn">Logout</button>
          </>
        ) : (
          <>
            <a href="/writer">Dashboard</a>
            <a href="/writer/new">New Article</a>
            {userName && <span class="ftn-user">{userName}</span>}
            <button id="logoutBtn" class="ftn-logout-btn">Logout</button>
          </>
        )}
      </nav>
    </div>
  )}
</header>

<style>
  .ftn-header-logo-always {
    display: block;
    max-height: 80px;
    width: auto;
    margin: 0 auto;
  }
</style>

{(role === 'admin' || role === 'editor') && (
  <script is:inline>
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/';
    });
  </script>
)}
