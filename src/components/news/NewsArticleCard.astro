---
import { getImageUrl } from '@/lib/db-utils';

interface Article {
  id: number;
  title: string;
  slug: string;
  excerpt?: string;
  content?: string;
  featured_image?: string;
  author_name: string;
  author_handle?: string;
  published_at?: string;
  created_at: string;
  category?: string;
}

interface Props {
  article: Article;
  r2PublicUrl?: string;
  index?: number;
}

const { article, r2PublicUrl = '', index = 0 } = Astro.props;

// Use the helper function to construct proper image URL
const imageUrl = getImageUrl(article.featured_image, r2PublicUrl);

const formattedDate = new Date(article.published_at || article.created_at).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Get author handle
const authorHandle = article.author_handle || '@fishtanklive';
const twitterUrl = authorHandle.startsWith('@') 
  ? `https://x.com/${authorHandle.substring(1)}` 
  : `https://x.com/${authorHandle}`;

// Extract first paragraph from content for main page display
function getFirstParagraph(content: string | undefined): string {
  if (!content) return '';
  // Remove markdown formatting and split into paragraphs
  const cleanContent = content.replace(/^#+\s+.*/gm, '').replace(/\s*[\r\n]+\s*/g, '\n\n');
  const paragraphs = cleanContent.split(/\n\n+/).map(p => p.trim()).filter(p => p.length > 0);
  const firstPara = paragraphs[0] || '';
  // Remove remaining markdown characters
  return firstPara.replace(/[*_#\[\]`]/g, '').substring(0, 300);
}

const mainText = getFirstParagraph(article.content);

// Determine article classes based on category
// Convert category to valid CSS class by lowercasing and replacing spaces with hyphens
// e.g., "fake news" becomes "fake-news" to match filter button data-filter values
const categoryClass = article.category?.toLowerCase().replace(/\s+/g, '-') || 'all';
const articleClasses = `article ftn-article-card all ${categoryClass}`;
---

<article class={articleClasses} style={`--index: ${index + 1};`}>
  <h2 class="ftn-article-title">
    <a href={`/news/articles/${article.slug}`}>{article.title}</a>
  </h2>
  
  {imageUrl && (
    <div class="ftn-article-image">
      <img src={imageUrl} alt={article.title} class="article-thumbnail" />
    </div>
  )}

  {article.excerpt && (
    <p class="ftn-article-excerpt-subtitle">{article.excerpt}</p>
  )}
  
  <div class="ftn-article-content article-content">
    {mainText && (
      <p class="ftn-article-main-text">{mainText}</p>
    )}
  </div>
  
  <span class="tag ftn-article-meta">
    {article.author_name} | <a href={twitterUrl} target="_blank" rel="noopener" style="color: var(--aged-sepia); font-weight: 700;">{authorHandle}</a> | {formattedDate}
    {article.category && (
      <span> | <span style="font-weight: 700; color: var(--ink-black);">{article.category.toUpperCase()}</span></span>
    )}
  </span>
</article>
