---
import '@/styles/main.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Fishtank News',
  description = 'Latest news and updates from Fishtank'
} = Astro.props;

const fullTitle = title === 'Fishtank News' ? title : `${title} - Fishtank News`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
