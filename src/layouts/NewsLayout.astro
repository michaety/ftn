---
import '@/styles/news.css';
import NewsHeader from '@/components/news/NewsHeader.astro';
import NewsFooter from '@/components/news/NewsFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  role?: 'public' | 'admin' | 'editor';
  userName?: string;
  hideNavigation?: boolean;
}

const { 
  title = 'Fishtank News',
  description = 'Latest news and updates',
  image,
  role = 'public',
  userName,
  hideNavigation = false
} = Astro.props;

const fullTitle = title === 'Fishtank News' ? title : `${title} - Fishtank News`;

// Use custom image if provided, otherwise fall back to logo
const ogImage = image ? new URL(image, Astro.url) : new URL('/logo.webp', Astro.url);

// Build dynamic CSP that includes R2_PUBLIC_URL origin
const r2PublicUrl = Astro.locals.runtime.env.R2_PUBLIC_URL || '';
let r2Origin = '';
if (r2PublicUrl) {
  try {
    r2Origin = new URL(r2PublicUrl).origin;
  } catch (e) {
    // Log warning if URL parsing fails to aid in debugging
    console.warn(`Invalid R2_PUBLIC_URL: ${r2PublicUrl}`, e);
  }
}

// Build CSP directives
const imgSrcs = [
  "'self'",
  'https://img.fishtank.news',
  ...(r2Origin ? [r2Origin] : []),
  'https://*.twimg.com',
  'https://pbs.twimg.com',
  'https://syndication.twitter.com',
  'https://www.transparenttextures.com',
  'https://upload.wikimedia.org',
  'https://m.media-amazon.com',
  'https://i.ibb.co',
  'https://i.postimg.cc',
  'https://i.redd.it',
  'https://encrypted-tbn0.gstatic.com',
  'data:',
  'blob:'
].join(' ');

const styleSrcs = [
  "'self'",
  "'unsafe-inline'",
  'https://fonts.googleapis.com'
].join(' ');

const fontSrcs = [
  "'self'",
  'https://fonts.gstatic.com',
  'data:'
].join(' ');

const frameSrcs = [
  'https://platform.twitter.com',
  'https://twitter.com',
  'https://x.com',
  'https://syndication.twitter.com'
].join(' ');

const scriptSrcs = [
  "'self'",
  "'unsafe-inline'",
  'https://platform.twitter.com',
  'https://static.cloudflareinsights.com'
].join(' ');

const defaultSrcs = ["'self'"].join(' ');

const connectSrcs = ["'self'"].join(' ');

const cspContent = `img-src ${imgSrcs}; default-src ${defaultSrcs}; script-src ${scriptSrcs}; style-src ${styleSrcs}; connect-src ${connectSrcs}; font-src ${fontSrcs}; frame-src ${frameSrcs};`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta http-equiv="Content-Security-Policy" content={cspContent} />
    
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/thumbnail.png" />
    <link rel="icon" type="image/x-icon" href="/thumbnail.ico" />
    <link rel="apple-touch-icon" href="/thumbnail.png" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <title>{fullTitle}</title>
  </head>
  <body>
    <NewsHeader role={role} userName={userName} hideNavigation={hideNavigation} />
    <main>
      <slot />
    </main>
    <NewsFooter />
  </body>
</html>
