---
import '@/styles/main.css';
import NewsHeader from '@/components/news/NewsHeader.astro';
import NewsFooter from '@/components/news/NewsFooter.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Fishtank News',
  description = 'Latest news and updates'
} = Astro.props;

const fullTitle = title === 'Fishtank News' ? title : `${title} - Fishtank News`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <NewsHeader />
    <main>
      <slot />
    </main>
    <NewsFooter />
  </body>
</html>
